# Copy this file to .env.local and fill in the values.
# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Server-only: service_role key for admin/webhook routes that bypass RLS.
# Never prefix with NEXT_PUBLIC_ and never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# KYC at-rest encryption key (32 bytes, base64 or hex) for pandit ID numbers.
# Generate with: openssl rand -base64 32
# Leave blank to keep KYC dormant — applications then store only a masked ID,
# never the full number in plaintext.
KYC_ENCRYPTION_KEY=

# Live video poojas / consultations — Jitsi domain for the embedded room.
# Optional: defaults to the free meet.jit.si. Set to an 8x8 JaaS or self-hosted
# domain (e.g. 8x8.vc) for reliability, recording or JWT auth.
NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si

# Razorpay — Dashboard → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
# Razorpay webhook signing secret — Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=

# RazorpayX Payouts (priest payroll) — leave blank to keep payouts manual.
# Dashboard → RazorpayX → API keys, and your RazorpayX account number.
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
# RazorpayX webhook secret — Dashboard → Settings → Webhooks (payout.* events).
RAZORPAYX_WEBHOOK_SECRET=

# Error monitoring — Sentry DSN (leave blank to log to the console instead).
# Project → Settings → Client Keys (DSN).
SENTRY_DSN=

# Web push notifications — optional; the "Enable notifications" toggle and push
# sends stay dormant until set. Generate a key pair once:
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT is a mailto: or https: contact URL.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@bookmypoojari.com

# Public site URL (used for SEO metadata, sitemap, robots, OG tags)
NEXT_PUBLIC_SITE_URL=https://bookmypoojari.com

# Transactional email (Resend) — optional; emails are skipped until set.
# RESEND_API_KEY from resend.com; EMAIL_FROM like "BookMyPoojari <noreply@bookmypoojari.com>"
RESEND_API_KEY=
EMAIL_FROM=

# Phone OTP + transactional SMS (2Factor.in) — required for phone sign-in and
# SMS alerts. Leave blank to skip SMS (OTP login then won't work).
#   TWO_FACTOR_API_KEY  - your 2Factor.in API key
#   SMS_SENDER_ID       - approved 6-char DLT sender/header (e.g. BKMPJI)
TWO_FACTOR_API_KEY=
SMS_SENDER_ID=

# WhatsApp Cloud API (Meta) — optional; WhatsApp confirmations skipped until set.
#   WHATSAPP_TOKEN     - permanent/system-user access token
#   WHATSAPP_PHONE_ID  - WhatsApp Business phone-number id
#   WHATSAPP_LANG      - template language code (optional, default "en")
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_LANG=en

# Secret for the abandoned-cart cron route (Vercel Cron sends it as a Bearer token)
CRON_SECRET=

# Company details for tax invoices (optional; placeholders used if unset).
# Address lines separated by | (pipe).
NEXT_PUBLIC_COMPANY_NAME=BookMyPoojari Pvt. Ltd.
NEXT_PUBLIC_COMPANY_GSTIN=
NEXT_PUBLIC_COMPANY_ADDRESS=123 Temple Road|Bengaluru, Karnataka 560001
NEXT_PUBLIC_COMPANY_EMAIL=support@bookmypoojari.com
NEXT_PUBLIC_COMPANY_PHONE=+91 90000 00000

# Accounting email for the weekly CSV export cron
ACCOUNTING_EMAIL=
# Company state for GST place-of-supply (intra vs inter-state)
NEXT_PUBLIC_COMPANY_STATE=Karnataka
# Company UPI ID for invoice QR (optional; falls back to an info QR)
NEXT_PUBLIC_COMPANY_UPI=

# E-invoicing (IRP/GSP) — optional; e-invoice generation is a no-op until set
EINVOICE_API_URL=
EINVOICE_AUTH_TOKEN=
EINVOICE_CANCEL_URL=

# E-way bill (EWB/GSP) — optional; generation no-op until set. Threshold in INR.
EWB_API_URL=
EWB_AUTH_TOKEN=
EWB_THRESHOLD=50000
EWB_PARTB_URL=

# EWB expiry alerts (hourly cron) — emails a digest of e-way bills expiring soon.
# EWB_ALERT_EMAIL: recipient for the alert digest; falls back to ACCOUNTING_EMAIL if unset.
EWB_ALERT_EMAIL=
# EWB_ALERT_WINDOW_HOURS: alert when an EWB expires within this many hours (default 6).
EWB_ALERT_WINDOW_HOURS=6

# Optional path to a real JPEG logo embedded in invoice PDFs
INVOICE_LOGO_PATH=

# Optional: Google Distance Matrix API key for geo-based travel fees. When set
# (and egress is allowed), the booking flow refines the travel band by real
# driving distance/time; otherwise it falls back to the manual pincode bands.
GOOGLE_MAPS_API_KEY=
