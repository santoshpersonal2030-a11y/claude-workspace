# Online Pooja Stores — environment variables
# Copy to .env.local (web) and fill from your Supabase project: Settings → API.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Server-only (NEVER expose to the browser — used by admin/server routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Store config
NEXT_PUBLIC_STORE_NAME="Online Pooja Stores"
NEXT_PUBLIC_CURRENCY=INR
